# Alternative to config.json: copy to .env and fill in real values.
# Env vars override config.json if both are present. Never commit .env.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_ADDRESS=your-email@gmail.com
# Comma-separated list of recipients
SMTP_TO_ADDRESSES=your-email@gmail.com

# Optional: only needed for real college football stats instead of fixtures
CFBD_API_KEY=
